{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "identity-route": {
        "ClusterId": "identity-cluster",
        "AuthorizationPolicy": "anonymous",
        "Match": {
          "Path": "/auth/{**catch-all}"
        }
      },
      "users-route": {
        "ClusterId": "identity-cluster",
        "AuthorizationPolicy": "AdminOnly",
        "Match": {
          "Path": "/users/{**catch-all}"
        }
      },
      "projects-route": {
        "ClusterId": "project-cluster",
        "AuthorizationPolicy": "Authenticated",
        "Match": {
          "Path": "/projects/{**catch-all}"
        }
      },
      "rounds-route": {
        "ClusterId": "scheduling-cluster",
        "AuthorizationPolicy": "Authenticated",
        "Match": {
          "Path": "/rounds/{**catch-all}"
        }
      },
      "schedule-route": {
        "ClusterId": "scheduling-cluster",
        "AuthorizationPolicy": "Authenticated",
        "Match": {
          "Path": "/schedule/{**catch-all}"
        }
      },
      "evaluations-route": {
        "ClusterId": "evaluation-cluster",
        "AuthorizationPolicy": "Authenticated",
        "Match": {
          "Path": "/evaluations/{**catch-all}"
        }
      },
      "rebuttals-route": {
        "ClusterId": "evaluation-cluster",
        "AuthorizationPolicy": "Authenticated",
        "Match": {
          "Path": "/rebuttals/{**catch-all}"
        }
      },
      "reports-route": {
        "ClusterId": "evaluation-cluster",
        "AuthorizationPolicy": "Authenticated",
        "Match": {
          "Path": "/reports/{**catch-all}"
        }
      },
      "notifications-route": {
        "ClusterId": "notification-cluster",
        "AuthorizationPolicy": "Authenticated",
        "Match": {
          "Path": "/notifications/{**catch-all}"
        }
      },
      "notify-route": {
        "ClusterId": "notification-cluster",
        "AuthorizationPolicy": "ReviewStaff",
        "Match": {
          "Path": "/notify"
        }
      }
    },
    "Clusters": {
      "identity-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://identity-svc:8080"
          }
        }
      },
      "project-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://project-svc:8080"
          }
        }
      },
      "scheduling-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://scheduling-svc:8080"
          }
        }
      },
      "evaluation-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://evaluation-svc:8080"
          }
        }
      },
      "notification-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://notification-svc:8080"
          }
        }
      }
    }
  }
}
